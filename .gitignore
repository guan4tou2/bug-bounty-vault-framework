# Obsidian workspace state (machine-local)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/obsidian-git/data.json
.DS_Store
.trash/

# Smart Connections AI cache (rebuildable)
.smart-env/

# Graphify output (rebuildable, graph.json can reach hundreds of MB)
09 - Knowledge Base/graphify-out/
graphify-out/

# Workspace — local only, never goes to GitHub
# Contains: workshop/ reports/ firmware_analysis/ logs/ tmp/
# Structure documented in workspace/README.md
workspace/workshop/
workspace/reports/
workspace/firmware_analysis/
workspace/logs/
workspace/tmp/
.workspace_root

# Keep workspace README and scaffold tracked
!workspace/README.md
!workspace/workshop/_all/.gitkeep
!workspace/workshop/_example/

# Automation runtime state (machine-local)
automation/active_sessions/*.lock
automation/active_sessions/_expired/*.lock*

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Local audit logs
logs/

# LLM memory (machine-local)
memory/

# Secrets / local config
.env
.env.*
*.key
*.pem
*.p12
*.pfx
*.cookie
*.har

# Claude local settings
.claude/settings.local.json
