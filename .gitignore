# Local workspace / operational data
.workspace/
.vault-workspace/
scratch/
reports/
scan_results/
poc/
evidence/
rootfs/
extractions/
firmware_analysis/
logs/
tmp/

# Vault-root workspace scaffold is tracked, runtime contents are ignored.
workspace/*
!workspace/README.md
!workspace/.gitignore
!workspace/workshop/
workspace/workshop/*
!workspace/workshop/.gitkeep
!workspace/tools/
workspace/tools/*
!workspace/tools/.gitkeep
!workspace/reports/
workspace/reports/*
!workspace/reports/.gitkeep
!workspace/logs/
workspace/logs/*
!workspace/logs/.gitkeep

# Tool output
graphify-out/
.cache/
.pytest_cache/
__pycache__/
*.pyc

# Secrets / local config
.env
.env.*
*.key
*.pem
*.p12
*.pfx
*.cookie
*.har

# OS/editor
.DS_Store
.idea/
.vscode/
